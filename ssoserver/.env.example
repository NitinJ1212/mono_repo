# Server
PORT=3000
NODE_ENV=development
SSO_ISSUER=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssonitin
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=postgres

# JWT Keys (generate with: node src/utils/generateKeys.js)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_KEY_ID=sso-key-1

# Token TTLs
ACCESS_TOKEN_TTL=900         # 15 minutes in seconds
REFRESH_TOKEN_TTL=604800     # 7 days in seconds
AUTH_CODE_TTL=60             # 60 seconds

# Security
BCRYPT_ROUNDS=12
COOKIE_SECRET=change-this-to-a-long-random-secret
